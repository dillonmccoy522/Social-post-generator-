GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Long random string; the MCP endpoint lives at /mcp/<MCP_SECRET>
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
MCP_SECRET=
# IANA timezone for interpreting due dates/times (default America/Chicago)
BRIDGE_TZ=America/Chicago
PORT=3200
